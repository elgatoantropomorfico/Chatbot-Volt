# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/volt_chatbot?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-me-to-a-secure-random-string"
JWT_REFRESH_SECRET="change-me-to-another-secure-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# OpenAI
OPENAI_API_KEY="sk-..."

# WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN="your-verify-token"
WHATSAPP_API_VERSION="v21.0"
WHATSAPP_ACCESS_TOKEN="your-access-token"

# WooCommerce (per-tenant, but default for dev)
WOO_BASE_URL="https://your-store.com"
WOO_CONSUMER_KEY="ck_..."
WOO_CONSUMER_SECRET="cs_..."

# Server
PORT=3001
HOST="0.0.0.0"
NODE_ENV="development"
